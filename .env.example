# Salin ke .env.local dan isi nilainya. JANGAN commit .env.local.

# Database — MySQL via Docker (docker compose up -d); produksi: MySQL serverless (mis. PlanetScale)
DATABASE_URL="mysql://root:root@localhost:3307/asterra_studio"

# Opsional — override default docker-compose (root password / db / port host)
# MYSQL_ROOT_PASSWORD="root"
# MYSQL_DATABASE="asterra_studio"
# MYSQL_PORT="3307"

# Auth.js (NextAuth v5) — AUTH_SECRET wajib; NEXTAUTH_* opsional (kompatibilitas)
AUTH_SECRET="ganti-dengan-random-string"
NEXTAUTH_SECRET="ganti-dengan-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Cloudinary (upload gambar produk)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Kredensial admin awal (dipakai prisma/seed.ts — tiket P1-03)
SEED_ADMIN_EMAIL="admin@asterra.local"
SEED_ADMIN_PASSWORD="ganti-password-kuat"
